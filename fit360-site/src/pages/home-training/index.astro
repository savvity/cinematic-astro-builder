---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/sections/Navbar.astro';
import Footer from '../../components/sections/Footer.astro';
import { Icon } from 'astro-icon/components';
import { brand } from '../../data/brand';
import { servicePageSchema } from '../../lib/schema';

const faqs = [
  {
    question: 'Do I need equipment?',
    answer: 'No. We design bodyweight-only plans if preferred. Equipment can also be delivered to your home as part of your program.',
  },
  {
    question: 'How does my coach stay in touch?',
    answer: 'Via WhatsApp messages, calls, or video sessions, depending on your preference and your program type.',
  },
  {
    question: 'Can I switch to studio training later?',
    answer: 'Yes. Home and studio training can be combined or switched at any time. Many clients use both.',
  },
  {
    question: 'Is home training available outside Kharadi?',
    answer: 'Yes. Home training coaching is available anywhere in Pune. Equipment delivery covers most areas of the city.',
  },
];

const schema = servicePageSchema(
  brand,
  {
    name: 'Home Training',
    slug: 'home-training',
    description: 'FIT360 delivers expert personal training to your home in Pune. Personalized programs, equipment delivery, and weekly coaching check-ins.',
  },
  faqs,
);

const title = 'Home Workout Plans in Pune | Train From Home | FIT360';
const description = 'FIT360 delivers expert personal training to your home in Pune. Personalized programs, equipment delivery, and weekly coaching check-ins. Start today.';
---
<BaseLayout {title} {description} {schema}>
  <Navbar />

  <section class="relative pt-32 pb-20 px-8 md:px-16 overflow-hidden">
    <img src="/images/home-training.webp" alt="Home workout equipment delivered by FIT360 to Pune apartment"
      class="absolute inset-0 w-full h-full object-cover opacity-40" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-bg)]/30 via-[var(--color-bg)]/60 to-[var(--color-bg)]"></div>
    <div class="relative z-10 max-w-4xl">
      <nav class="flex items-center gap-2 font-[var(--font-mono)] text-xs text-[var(--color-muted)] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[var(--color-accent)] transition-colors">Home</a>
        <Icon name="ph:caret-right" class="size-3" />
        <span class="text-[var(--color-accent)]">Home Training</span>
      </nav>
      <p class="font-[var(--font-mono)] text-xs text-[var(--color-accent)] tracking-widest mb-4">PUNE-WIDE DELIVERY</p>
      <h1 class="font-[var(--font-drama)] italic text-[clamp(2.5rem,6vw,5rem)] text-[var(--color-primary)] leading-tight mb-6">
        Home Workout Plans in Pune: Expert Coaching Delivered to Your Door
      </h1>
      <p class="text-lg text-[var(--color-muted)] max-w-2xl leading-relaxed mb-8">
        FIT360 home training gives you the same expert coaching as our studio program, delivered to your home anywhere in Pune. Equipment delivered. Coach available. Progress tracked.
      </p>
      <a href="/contact/" class="btn-magnetic inline-flex bg-[var(--color-accent)] text-white px-8 py-4 rounded-full font-semibold">
        <span class="relative z-10 flex items-center gap-2">Book a Free Consultation <Icon name="ph:arrow-right-bold" class="size-5" /></span>
        <span class="btn-bg bg-[var(--color-primary)] rounded-full"></span>
      </a>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="py-20 px-8 md:px-16">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-[var(--font-drama)] italic text-[clamp(1.8rem,4vw,3rem)] text-[var(--color-primary)] mb-12">How It Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { step: '01', title: 'Free Online Fitness Assessment', desc: 'We review your health history, conditions, goals, and home setup. This happens by video or WhatsApp, no travel needed.' },
          { step: '02', title: 'Personalized Plan with Video Guides', desc: 'You receive a fully customized program with clear video demonstrations for every exercise. Designed for your space, your equipment, your conditions.' },
          { step: '03', title: 'Weekly Coach Check-ins', desc: 'Your coach checks in every week via WhatsApp or video call. Plans are adjusted based on your feedback, progress, and how your body responds.' },
        ].map((step) => (
          <div class="bg-white border border-[var(--color-dark)]/8 rounded-3xl p-8">
            <p class="font-[var(--font-mono)] text-2xl text-[var(--color-accent)] mb-4">{step.step}</p>
            <h3 class="font-[var(--font-heading)] font-bold text-lg mb-3">{step.title}</h3>
            <p class="text-[var(--color-muted)] text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="py-20 px-8 md:px-16 bg-[var(--color-primary)]">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-[var(--font-drama)] italic text-[clamp(1.8rem,4vw,3rem)] text-[var(--color-bg)] mb-10">What's Included</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {[
          { title: 'Custom Home Workout Plan', desc: 'Designed specifically for your conditions, goals, available space, and equipment.', icon: 'ph:clipboard-fill' },
          { title: 'Video Demonstrations', desc: 'Every exercise comes with a clear video guide. No guessing on form or technique.', icon: 'ph:video-fill' },
          { title: 'Optional Equipment Delivery', desc: 'Dumbbells, resistance bands, and posture aids delivered to your home. Pay only for what you need.', icon: 'ph:package-fill' },
          { title: 'Weekly Coach Check-ins', desc: 'Regular communication with your coach to adjust your plan and keep you progressing.', icon: 'ph:chat-circle-fill' },
          { title: 'Nutritionist Integration', desc: 'Optional: connect with FIT360 nutritionist for a complete home health coaching program.', icon: 'ph:bowl-food-fill' },
          { title: 'Studio Option Anytime', desc: 'Home and studio training are interchangeable. Visit the Kharadi studio whenever it suits you.', icon: 'ph:buildings-fill' },
        ].map((item) => (
          <div class="flex gap-4">
            <div class="w-10 h-10 bg-[var(--color-bg)]/10 rounded-xl flex items-center justify-center shrink-0">
              <Icon name={item.icon} class="size-5 text-[var(--color-accent)]" />
            </div>
            <div>
              <h3 class="font-[var(--font-heading)] font-bold text-[var(--color-bg)] mb-1">{item.title}</h3>
              <p class="text-[var(--color-bg)]/60 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHO IT'S FOR -->
  <section class="py-20 px-8 md:px-16 bg-[var(--color-primary)]/5">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-[var(--font-drama)] italic text-[clamp(1.8rem,4vw,3rem)] text-[var(--color-primary)] mb-10">Who Home Training Is For</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {[
          'Busy parents and professionals with unpredictable schedules',
          'People living outside easy distance of Kharadi',
          'Those with social anxiety about gym environments',
          'Clients managing conditions that limit travel',
          'Anyone who wants the flexibility of training at home',
          'Existing studio clients who want sessions at home on travel weeks',
        ].map((item) => (
          <div class="flex items-start gap-3 bg-white rounded-2xl p-5 border border-[var(--color-dark)]/8">
            <Icon name="ph:check-circle-fill" class="size-5 text-[var(--color-accent)] shrink-0 mt-0.5" />
            <p class="text-sm leading-relaxed">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-8 md:px-16">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-[var(--font-drama)] italic text-[clamp(1.8rem,4vw,3rem)] text-[var(--color-primary)] mb-10">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-white border border-[var(--color-dark)]/8 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between p-6 cursor-pointer font-[var(--font-heading)] font-semibold">
              {faq.question}
              <Icon name="ph:caret-down" class="size-5 text-[var(--color-accent)] group-open:rotate-180 transition-transform" />
            </summary>
            <div class="px-6 pb-6 text-[var(--color-muted)] leading-relaxed">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-8 md:px-16 bg-[var(--color-accent)]">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-[var(--font-drama)] italic text-3xl md:text-5xl text-white mb-4">Start Home Training Today</h2>
      <p class="text-white/80 mb-8 text-lg">Book a free consultation and we'll design your home program within 48 hours.</p>
      <a href="/contact/" class="btn-magnetic inline-flex bg-white text-[var(--color-accent)] px-10 py-5 rounded-full text-lg font-bold">
        <span class="relative z-10 flex items-center gap-2">Book Free Consultation <Icon name="ph:arrow-right-bold" class="size-5" /></span>
        <span class="btn-bg bg-[var(--color-primary)] rounded-full"></span>
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>
