---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/sections/Navbar.astro';
import Footer from '../../components/sections/Footer.astro';
import { Icon } from 'astro-icon/components';
import { brand } from '../../data/brand';
import { medicalBusinessPageSchema } from '../../lib/schema';

const faqs = [
  {
    question: 'Are the workouts safe with PCOD?',
    answer: 'Yes. All exercises are structured, low-impact, and anti-inflammatory, designed around your individual cycle and symptoms.',
  },
  {
    question: 'Will I lose weight?',
    answer: 'Weight loss may occur as a secondary benefit. The primary focus is hormonal healing and improving your metabolism.',
  },
  {
    question: 'Do I need to follow a strict diet?',
    answer: 'No. FIT360 uses realistic, hormone-friendly nutrition strategies without restrictive or crash diets.',
  },
  {
    question: 'Is remote coaching available?',
    answer: 'Yes. Full remote coaching with video guides, equipment delivery, and weekly check-ins is available.',
  },
];

const schema = medicalBusinessPageSchema(
  brand,
  {
    name: 'PCOD Reversal Program',
    slug: 'pcod-reversal',
    description: "FIT360's PCOD reversal program in Pune uses science-backed exercise and nutrition to restore hormonal balance, improve cycle regularity, and reverse insulin resistance naturally.",
  },
  faqs,
);

const title = 'PCOD Reversal Program Pune | FIT360';
const description = "FIT360's PCOD reversal program in Pune uses science-backed exercise and nutrition to restore hormonal balance, improve cycle regularity, and reverse insulin resistance naturally.";
---
<BaseLayout {title} {description} {schema}>
  <Navbar />

  <section class="relative pt-32 pb-20 px-8 md:px-16 overflow-hidden">
    <img src="/images/conditions.webp" alt="Woman doing therapeutic exercises for PCOD at FIT360 Pune"
      class="absolute inset-0 w-full h-full object-cover opacity-40" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-bg)]/30 via-[var(--color-bg)]/60 to-[var(--color-bg)]"></div>
    <div class="relative z-10 max-w-4xl">
      <nav class="flex items-center gap-2 font-[var(--font-mono)] text-xs text-[var(--color-muted)] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[var(--color-accent)] transition-colors">Home</a>
        <Icon name="ph:caret-right" class="size-3" />
        <span class="text-[var(--color-accent)]">PCOD Reversal</span>
      </nav>
      <p class="font-[var(--font-mono)] text-xs text-[var(--color-accent)] tracking-widest mb-4">CONDITION-SPECIFIC PROGRAM</p>
      <h1 class="font-[var(--font-drama)] italic text-[clamp(2.5rem,6vw,5rem)] text-[var(--color-primary)] leading-tight mb-6">
        PCOD Reversal Through Exercise in Pune: A Natural, Sustainable Approach
      </h1>
      <p class="text-lg text-[var(--color-muted)] max-w-2xl leading-relaxed mb-8">
        PCOD (Polycystic Ovarian Disease) affects millions of women in India. Most treatment approaches focus on medication or extreme diets. FIT360's approach uses clinical exercise science and hormone-friendly nutrition to address the root causes of PCOD naturally.
      </p>
      <a href="/contact/" class="btn-magnetic inline-flex bg-[var(--color-accent)] text-white px-8 py-4 rounded-full font-semibold">
        <span class="relative z-10 flex items-center gap-2">Book a Free Consultation <Icon name="ph:arrow-right-bold" class="size-5" /></span>
        <span class="btn-bg bg-[var(--color-primary)] rounded-full"></span>
      </a>
    </div>
  </section>

  <!-- WHY EXERCISE WORKS -->
  <section class="py-20 px-8 md:px-16">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-[var(--font-drama)] italic text-[clamp(1.8rem,4vw,3rem)] text-[var(--color-primary)] mb-10">Why Exercise Works for PCOD</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Improves Insulin Sensitivity', desc: 'Exercise makes your cells more responsive to insulin, directly addressing the metabolic root of PCOD.', icon: 'ph:drop-fill' },
          { title: 'Balances Hormones', desc: 'The right training reduces excess androgens and helps regulate estrogen, progesterone, and testosterone levels.', icon: 'ph:flower-fill' },
          { title: 'Reduces Inflammation', desc: 'Low-impact strength and mobility work reduces systemic inflammation, a key driver of PCOD symptoms.', icon: 'ph:shield-check-fill' },
          { title: 'Boosts Cycle Regularity', desc: 'Regular, appropriate exercise directly improves ovulation frequency and menstrual regularity over time.', icon: 'ph:calendar-fill' },
          { title: 'Reduces Cortisol', desc: 'Well-programmed exercise reduces stress hormones that worsen PCOD symptoms and disrupt sleep.', icon: 'ph:brain-fill' },
          { title: 'Reduces Abdominal Fat', desc: 'Targeted programming reduces visceral fat, which directly worsens insulin resistance in PCOD.', icon: 'ph:chart-line-up-fill' },
        ].map((point) => (
          <div class="bg-white border border-[var(--color-dark)]/8 rounded-3xl p-6">
            <div class="w-10 h-10 bg-[var(--color-accent)]/10 rounded-xl flex items-center justify-center mb-4">
              <Icon name={point.icon} class="size-5 text-[var(--color-accent)]" />
            </div>
            <h3 class="font-[var(--font-heading)] font-bold mb-2">{point.title}</h3>
            <p class="text-[var(--color-muted)] text-sm leading-relaxed">{point.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3-STEP APPROACH -->
  <section class="py-20 px-8 md:px-16 bg-[var(--color-primary)]">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-[var(--font-drama)] italic text-[clamp(1.8rem,4vw,3rem)] text-[var(--color-bg)] mb-12">Our 3-Step Approach</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { step: '01', title: 'Full Assessment', desc: 'We review your menstrual history, energy levels, stress patterns, diet habits, and lifestyle before designing any program.' },
          { step: '02', title: 'Personalized PCOD-Safe Program', desc: 'Your program combines strength training, low-impact cardio, and restorative movement — timed around your cycle for maximum hormonal benefit.' },
          { step: '03', title: 'Weekly Coaching and Adjustments', desc: 'Your coach and nutritionist review your progress weekly and adjust the program based on your cycle, energy, and symptoms.' },
        ].map((step) => (
          <div class="border border-[var(--color-bg)]/20 rounded-3xl p-8">
            <p class="font-[var(--font-mono)] text-2xl text-[var(--color-accent)] mb-4">{step.step}</p>
            <h3 class="font-[var(--font-heading)] font-bold text-[var(--color-bg)] text-lg mb-3">{step.title}</h3>
            <p class="text-[var(--color-bg)]/60 text-sm leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="py-20 px-8 md:px-16 bg-[var(--color-primary)]/5">
    <div class="max-w-3xl mx-auto">
      <div class="bg-white border border-[var(--color-dark)]/8 rounded-3xl p-10">
        <div class="flex mb-4">
          <Icon name="ph:star-fill" class="size-5 text-yellow-400" />
          <Icon name="ph:star-fill" class="size-5 text-yellow-400" />
          <Icon name="ph:star-fill" class="size-5 text-yellow-400" />
          <Icon name="ph:star-fill" class="size-5 text-yellow-400" />
          <Icon name="ph:star-fill" class="size-5 text-yellow-400" />
        </div>
        <Icon name="ph:quotes-fill" class="size-10 text-[var(--color-accent)]/30 mb-6" />
        <p class="font-[var(--font-drama)] italic text-2xl text-[var(--color-primary)] leading-relaxed mb-8">
          I tried diets, pills, and gym workouts for years with no real change. After 3 months with FIT360, I have regular periods, more energy, and I actually feel in control of my body.
        </p>
        <div>
          <p class="font-[var(--font-heading)] font-bold">Riya</p>
          <p class="font-[var(--font-mono)] text-xs text-[var(--color-muted)]">28, Kharadi — PCOD Program Client</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-8 md:px-16">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-[var(--font-drama)] italic text-[clamp(1.8rem,4vw,3rem)] text-[var(--color-primary)] mb-10">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-white border border-[var(--color-dark)]/8 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between p-6 cursor-pointer font-[var(--font-heading)] font-semibold">
              {faq.question}
              <Icon name="ph:caret-down" class="size-5 text-[var(--color-accent)] group-open:rotate-180 transition-transform" />
            </summary>
            <div class="px-6 pb-6 text-[var(--color-muted)] leading-relaxed">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-8 md:px-16 bg-[var(--color-accent)]">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-[var(--font-drama)] italic text-3xl md:text-5xl text-white mb-4">Book Your Free PCOD Consultation</h2>
      <p class="text-white/80 mb-8 text-lg">We'll review your health history and show you exactly what a PCOD-specific program looks like for your body.</p>
      <a href="/contact/" class="btn-magnetic inline-flex bg-white text-[var(--color-accent)] px-10 py-5 rounded-full text-lg font-bold">
        <span class="relative z-10 flex items-center gap-2">Book Free Consultation <Icon name="ph:arrow-right-bold" class="size-5" /></span>
        <span class="btn-bg bg-[var(--color-primary)] rounded-full"></span>
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>
