---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/sections/Navbar.astro';
import Footer from '../../components/sections/Footer.astro';
import { Icon } from 'astro-icon/components';
import { brand } from '../../data/brand';
import { servicePageSchema } from '../../lib/schema';

const faqs = [
  {
    question: 'What is the difference between a personal trainer and an exercise specialist?',
    answer: 'An exercise specialist holds advanced qualifications in clinical exercise physiology. They design programs for clients with complex medical conditions, structural issues, and chronic pain that require a higher level of expertise than standard personal training.',
  },
  {
    question: 'Do I need a referral from my doctor?',
    answer: 'No referral is required, but we do request your medical history and any relevant test results so we can design the safest and most effective program for you.',
  },
  {
    question: 'Can the exercise specialist work alongside my physiotherapist?',
    answer: 'Yes. We regularly coordinate with physiotherapists, orthopaedic specialists, and other healthcare providers to ensure your exercise program complements your broader treatment plan.',
  },
  {
    question: 'Is this service available for home training?',
    answer: 'Yes. Exercise specialist programming can be delivered as studio sessions or home training with video guides and regular check-ins.',
  },
];

const schema = servicePageSchema(
  brand,
  {
    name: 'Exercise Specialist',
    slug: 'exercise-specialist',
    description: "FIT360's exercise specialists in Kharadi, Pune design advanced fitness programs for complex health conditions, postural correction, and rehabilitation.",
  },
  faqs,
);

const title = 'Exercise Specialist Kharadi | FIT360';
const description = "FIT360's exercise specialists in Kharadi, Pune design advanced fitness programs for complex health conditions, postural correction, and rehabilitation.";
---
<BaseLayout {title} {description} {schema}>
  <Navbar />

  <section class="relative pt-32 pb-20 px-8 md:px-16 overflow-hidden">
    <img src="/images/conditions.webp" alt="Exercise specialist working with client on therapeutic movement at FIT360"
      class="absolute inset-0 w-full h-full object-cover opacity-40" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-bg)]/30 via-[var(--color-bg)]/60 to-[var(--color-bg)]"></div>
    <div class="relative z-10 max-w-4xl">
      <nav class="flex items-center gap-2 font-[var(--font-mono)] text-xs text-[var(--color-muted)] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[var(--color-accent)] transition-colors">Home</a>
        <Icon name="ph:caret-right" class="size-3" />
        <span class="text-[var(--color-accent)]">Exercise Specialist</span>
      </nav>
      <p class="font-[var(--font-mono)] text-xs text-[var(--color-accent)] tracking-widest mb-4">CLINICAL EXERCISE PROGRAMMING</p>
      <h1 class="font-[var(--font-drama)] italic text-[clamp(2.5rem,6vw,5rem)] text-[var(--color-primary)] leading-tight mb-6">
        Exercise Specialist in Kharadi: Advanced Programming for Complex Conditions
      </h1>
      <p class="text-lg text-[var(--color-muted)] max-w-2xl leading-relaxed mb-8">
        An exercise specialist goes beyond personal training. FIT360's exercise specialists design clinical-grade movement programs for clients with complex health conditions, structural issues, and chronic pain who need more than a standard fitness plan.
      </p>
      <a href="/contact/" class="btn-magnetic inline-flex bg-[var(--color-accent)] text-white px-8 py-4 rounded-full font-semibold">
        <span class="relative z-10 flex items-center gap-2">Book a Free Consultation <Icon name="ph:arrow-right-bold" class="size-5" /></span>
        <span class="btn-bg bg-[var(--color-primary)] rounded-full"></span>
      </a>
    </div>
  </section>

  <section class="py-20 px-8 md:px-16">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <h2 class="font-[var(--font-drama)] italic text-[clamp(1.8rem,4vw,3rem)] text-[var(--color-primary)] mb-8">Who This Service Is For</h2>
          <div class="space-y-4">
            {[
              'People with chronic pain or unresolved injury',
              'Post-rehabilitation clients cleared for exercise',
              'Those with complex conditions needing medical-grade programming',
              'Clients requiring postural correction and functional movement work',
              'Athletes returning from surgery or injury',
              'Anyone whose conditions require coordination with a healthcare team',
            ].map((item) => (
              <div class="flex items-start gap-3">
                <Icon name="ph:check-circle-fill" class="size-5 text-[var(--color-accent)] shrink-0 mt-0.5" />
                <p class="leading-relaxed">{item}</p>
              </div>
            ))}
          </div>
        </div>
        <div>
          <h2 class="font-[var(--font-drama)] italic text-[clamp(1.8rem,4vw,3rem)] text-[var(--color-primary)] mb-8">What's Included</h2>
          <div class="space-y-6">
            {[
              { title: 'Movement Screening and Postural Assessment', desc: 'Detailed analysis of movement patterns, compensations, and structural imbalances before programming begins.', icon: 'ph:scan-fill' },
              { title: 'Corrective Exercise Programming', desc: 'Targeted exercises to address specific muscular imbalances, mobility restrictions, and pain patterns.', icon: 'ph:path-fill' },
              { title: 'Condition-Specific Protocols', desc: 'Programs designed around your specific condition: PCOD, diabetes, arthritis, sciatica, spondylitis, or post-surgical rehab.', icon: 'ph:heartbeat-fill' },
              { title: 'Medical Team Integration', desc: 'We coordinate with your physiotherapist, orthopaedic specialist, or GP when relevant to your program.', icon: 'ph:users-three-fill' },
            ].map((point) => (
              <div class="flex gap-4">
                <div class="w-10 h-10 bg-[var(--color-accent)]/10 rounded-xl flex items-center justify-center shrink-0">
                  <Icon name={point.icon} class="size-5 text-[var(--color-accent)]" />
                </div>
                <div>
                  <h3 class="font-[var(--font-heading)] font-bold mb-1">{point.title}</h3>
                  <p class="text-[var(--color-muted)] text-sm leading-relaxed">{point.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-8 md:px-16">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-[var(--font-drama)] italic text-[clamp(1.8rem,4vw,3rem)] text-[var(--color-primary)] mb-10">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-white border border-[var(--color-dark)]/8 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between p-6 cursor-pointer font-[var(--font-heading)] font-semibold">
              {faq.question}
              <Icon name="ph:caret-down" class="size-5 text-[var(--color-accent)] group-open:rotate-180 transition-transform" />
            </summary>
            <div class="px-6 pb-6 text-[var(--color-muted)] leading-relaxed">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-8 md:px-16 bg-[var(--color-accent)]">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-[var(--font-drama)] italic text-3xl md:text-5xl text-white mb-4">Start with a Free Assessment</h2>
      <p class="text-white/80 mb-8 text-lg">We'll review your condition, movement patterns, and goals before recommending a program.</p>
      <a href="/contact/" class="btn-magnetic inline-flex bg-white text-[var(--color-accent)] px-10 py-5 rounded-full text-lg font-bold">
        <span class="relative z-10 flex items-center gap-2">Book Free Consultation <Icon name="ph:arrow-right-bold" class="size-5" /></span>
        <span class="btn-bg bg-[var(--color-primary)] rounded-full"></span>
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>
