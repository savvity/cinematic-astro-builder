---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/sections/Navbar.astro';
import Footer from '../../components/sections/Footer.astro';
import { Icon } from 'astro-icon/components';
import { brand } from '../../data/brand';
import { aboutPageSchema } from '../../lib/schema';

const schema = aboutPageSchema(brand);
const title = 'About FIT360 | Personal Training Studio in Kharadi, Pune';
const description = "FIT360 is Kharadi's multidisciplinary health and fitness studio. Learn about our team of trainers, nutritionists, and exercise specialists dedicated to science-backed results.";
---
<BaseLayout {title} {description} {schema}>
  <Navbar />

  <section class="relative pt-32 pb-20 px-8 md:px-16 overflow-hidden">
    <img src="/images/team.webp" alt="FIT360 team in Kharadi Pune"
      class="absolute inset-0 w-full h-full object-cover opacity-40" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-bg)]/30 via-[var(--color-bg)]/60 to-[var(--color-bg)]"></div>
    <div class="relative z-10 max-w-4xl">
      <nav class="flex items-center gap-2 font-[var(--font-mono)] text-xs text-[var(--color-muted)] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[var(--color-accent)] transition-colors">Home</a>
        <Icon name="ph:caret-right" class="size-3" />
        <span class="text-[var(--color-accent)]">About</span>
      </nav>
      <p class="font-[var(--font-mono)] text-xs text-[var(--color-accent)] tracking-widest mb-4">KHARADI, PUNE</p>
      <h1 class="font-[var(--font-drama)] italic text-[clamp(2.5rem,6vw,5rem)] text-[var(--color-primary)] leading-tight mb-6">
        About FIT360: A Multidisciplinary Approach to Health and Fitness
      </h1>
      <p class="text-lg text-[var(--color-muted)] max-w-2xl leading-relaxed">
        FIT360 exists because generic fitness doesn't work for most people. We built a studio where personal trainers, licensed nutritionists, and exercise specialists collaborate on programs designed for your specific body, health conditions, and goals.
      </p>
    </div>
  </section>

  <!-- THE 360 PHILOSOPHY -->
  <section class="py-20 px-8 md:px-16 bg-[var(--color-primary)]">
    <div class="max-w-4xl mx-auto">
      <p class="font-[var(--font-mono)] text-xs text-[var(--color-accent)] tracking-widest mb-4">OUR PHILOSOPHY</p>
      <h2 class="font-[var(--font-drama)] italic text-[clamp(2rem,5vw,4rem)] text-[var(--color-bg)] mb-8">
        The 360 Approach
      </h2>
      <p class="text-[var(--color-bg)]/80 text-xl leading-relaxed mb-6">
        The name FIT360 reflects our philosophy. Health has no single answer.
      </p>
      <p class="text-[var(--color-bg)]/60 leading-relaxed mb-6">
        Fitness alone does not reverse PCOD. Nutrition alone does not eliminate back pain. Real results come from a 360 approach that integrates movement, food, and recovery into a single coordinated plan.
      </p>
      <p class="text-[var(--color-bg)]/60 leading-relaxed">
        Every client at FIT360 works with a team, not just a trainer. Your personal trainer, licensed nutritionist, and exercise specialist review your progress together and adjust your program based on real data. This is what separates us from every gym in Pune.
      </p>
    </div>
  </section>

  <!-- THE TEAM -->
  <section class="py-20 px-8 md:px-16">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-[var(--font-drama)] italic text-[clamp(1.8rem,4vw,3rem)] text-[var(--color-primary)] mb-12">The FIT360 Team</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        {[
          {
            role: 'Personal Trainers',
            desc: 'Certified trainers who understand chronic health conditions. Every session is 1-on-1, every program is built from your assessment. No cookie-cutter plans. No group classes.',
            icon: 'ph:person-simple-run-fill',
          },
          {
            role: 'Licensed Nutritionists',
            desc: 'Our nutrition team creates evidence-based meal plans that integrate with your training. No crash diets, no generic meal plans. Food strategies built for Indian lifestyles.',
            icon: 'ph:bowl-food-fill',
          },
          {
            role: 'Exercise Specialists',
            desc: 'Clinical-grade movement programmers for complex conditions, postural rehabilitation, and performance optimization. They coordinate with your medical team when needed.',
            icon: 'ph:heartbeat-fill',
          },
        ].map((member) => (
          <div class="bg-white border border-[var(--color-dark)]/8 rounded-3xl p-8">
            <div class="w-12 h-12 bg-[var(--color-primary)]/10 rounded-2xl flex items-center justify-center mb-6">
              <Icon name={member.icon} class="size-6 text-[var(--color-primary)]" />
            </div>
            <h3 class="font-[var(--font-heading)] font-bold text-lg mb-4">{member.role}</h3>
            <p class="text-[var(--color-muted)] leading-relaxed">{member.desc}</p>
          </div>
        ))}
      </div>
      <div class="relative rounded-3xl overflow-hidden">
        <img src="/images/team.webp" alt="FIT360 team at the Kharadi studio"
          class="w-full h-[400px] object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-primary)]/70 to-transparent flex items-end p-8">
          <div class="flex items-center gap-3">
            <div class="flex">
              <Icon name="ph:star-fill" class="size-5 text-yellow-400" />
              <Icon name="ph:star-fill" class="size-5 text-yellow-400" />
              <Icon name="ph:star-fill" class="size-5 text-yellow-400" />
              <Icon name="ph:star-fill" class="size-5 text-yellow-400" />
              <Icon name="ph:star-half-fill" class="size-5 text-yellow-400" />
            </div>
            <p class="text-white font-[var(--font-heading)] font-semibold">4.6/5 from 14 Google Reviews</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE STUDIO -->
  <section class="py-20 px-8 md:px-16 bg-[var(--color-primary)]/5">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="font-[var(--font-drama)] italic text-[clamp(1.8rem,4vw,3rem)] text-[var(--color-primary)] mb-8">The Studio</h2>
          <p class="text-[var(--color-muted)] leading-relaxed mb-6">
            FIT360 is located in the EON Free Zone area of Kharadi, one of Pune's fastest-growing neighborhoods. Our studio is purpose-built for private, focused training.
          </p>
          <div class="space-y-5">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-[var(--color-primary)]/10 rounded-xl flex items-center justify-center shrink-0">
                <Icon name="ph:map-pin-fill" class="size-5 text-[var(--color-primary)]" />
              </div>
              <div>
                <p class="font-semibold mb-1">Address</p>
                <p class="text-[var(--color-muted)]">Grant Rd, EON Free Zone, Kharadi, Pune, Maharashtra 411014</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-[var(--color-primary)]/10 rounded-xl flex items-center justify-center shrink-0">
                <Icon name="ph:clock-fill" class="size-5 text-[var(--color-primary)]" />
              </div>
              <div>
                <p class="font-semibold mb-1">Hours</p>
                <p class="text-[var(--color-muted)]">Monday to Saturday, 6:00 AM to 8:00 PM</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-[var(--color-primary)]/10 rounded-xl flex items-center justify-center shrink-0">
                <Icon name="ph:phone-call-fill" class="size-5 text-[var(--color-primary)]" />
              </div>
              <div>
                <p class="font-semibold mb-1">Phone</p>
                <a href="tel:+917397951908" class="text-[var(--color-accent)] hover:underline">+91 7397951908</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-[var(--color-primary)]/10 rounded-xl flex items-center justify-center shrink-0">
                <Icon name="ph:envelope-fill" class="size-5 text-[var(--color-primary)]" />
              </div>
              <div>
                <p class="font-semibold mb-1">Email</p>
                <a href="mailto:fit360kharadi@gmail.com" class="text-[var(--color-accent)] hover:underline">fit360kharadi@gmail.com</a>
              </div>
            </div>
          </div>
        </div>
        <img src="/images/hero.webp" alt="FIT360 private fitness studio in Kharadi"
          class="w-full h-[450px] object-cover rounded-3xl" loading="lazy" />
      </div>
    </div>
  </section>

  <section class="py-20 px-8 md:px-16 bg-[var(--color-accent)]">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-[var(--font-drama)] italic text-3xl md:text-5xl text-white mb-4">Ready to Meet the Team?</h2>
      <p class="text-white/80 mb-8 text-lg">Book a free consultation and see FIT360 for yourself. No commitment required.</p>
      <a href="/contact/" class="btn-magnetic inline-flex bg-white text-[var(--color-accent)] px-10 py-5 rounded-full text-lg font-bold">
        <span class="relative z-10 flex items-center gap-2">Book Free Consultation <Icon name="ph:arrow-right-bold" class="size-5" /></span>
        <span class="btn-bg bg-[var(--color-primary)] rounded-full"></span>
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>
