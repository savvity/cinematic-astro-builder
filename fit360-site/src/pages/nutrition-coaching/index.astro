---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/sections/Navbar.astro';
import Footer from '../../components/sections/Footer.astro';
import { Icon } from 'astro-icon/components';
import { brand } from '../../data/brand';
import { servicePageSchema } from '../../lib/schema';

const faqs = [
  {
    question: 'Do I need to follow a strict diet?',
    answer: 'No. FIT360 nutrition plans are built around your actual life. We account for eating out, social occasions, and your food preferences.',
  },
  {
    question: 'Can I do nutrition coaching without personal training?',
    answer: 'Yes. Nutrition coaching is available as a standalone service.',
  },
  {
    question: 'How often will I check in with my nutritionist?',
    answer: 'Weekly. Your nutritionist reviews your food diary every week and adjusts your plan based on your progress and feedback.',
  },
  {
    question: 'Are the meal plans suitable for Indian diets?',
    answer: 'Yes. All meal plans are designed around locally available Indian foods that fit your lifestyle and budget.',
  },
];

const schema = servicePageSchema(
  brand,
  {
    name: 'Nutrition Coaching',
    slug: 'nutrition-coaching',
    description: 'Licensed nutritionists in Kharadi, Pune. FIT360 creates science-backed meal plans for PCOD, diabetes, weight management, and hormonal health. No crash diets.',
  },
  faqs,
);

const title = 'Nutrition Coaching Kharadi Pune | FIT360';
const description = "Licensed nutritionists in Kharadi, Pune. FIT360 creates science-backed meal plans for PCOD, diabetes, weight management, and hormonal health. No crash diets.";
---
<BaseLayout {title} {description} {schema}>
  <Navbar />

  <section class="relative pt-32 pb-20 px-8 md:px-16 overflow-hidden">
    <img src="/images/nutrition.webp" alt="Nutritionist at FIT360 reviewing personalized meal plan"
      class="absolute inset-0 w-full h-full object-cover opacity-40" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--color-bg)]/30 via-[var(--color-bg)]/60 to-[var(--color-bg)]"></div>
    <div class="relative z-10 max-w-4xl">
      <nav class="flex items-center gap-2 font-[var(--font-mono)] text-xs text-[var(--color-muted)] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-[var(--color-accent)] transition-colors">Home</a>
        <Icon name="ph:caret-right" class="size-3" />
        <span class="text-[var(--color-accent)]">Nutrition Coaching</span>
      </nav>
      <p class="font-[var(--font-mono)] text-xs text-[var(--color-accent)] tracking-widest mb-4">SCIENCE-BACKED NUTRITION</p>
      <h1 class="font-[var(--font-drama)] italic text-[clamp(2.5rem,6vw,5rem)] text-[var(--color-primary)] leading-tight mb-6">
        Nutrition Coaching in Kharadi, Pune: Personalized Plans Backed by Science
      </h1>
      <p class="text-lg text-[var(--color-muted)] max-w-2xl leading-relaxed mb-8">
        FIT360 nutrition coaching is designed by licensed nutritionists who understand how food interacts with your health conditions, hormones, and exercise program. No crash diets. No generic meal plans.
      </p>
      <a href="/contact/" class="btn-magnetic inline-flex bg-[var(--color-accent)] text-white px-8 py-4 rounded-full font-semibold">
        <span class="relative z-10 flex items-center gap-2">Book a Free Consultation <Icon name="ph:arrow-right-bold" class="size-5" /></span>
        <span class="btn-bg bg-[var(--color-primary)] rounded-full"></span>
      </a>
    </div>
  </section>

  <section class="py-20 px-8 md:px-16 bg-[var(--color-primary)]/5">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-[var(--font-drama)] italic text-[clamp(1.8rem,4vw,3rem)] text-[var(--color-primary)] mb-10">Who This Program Is For</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          'Women managing PCOD or hormonal imbalances',
          'People with diabetes or insulin resistance',
          'Those seeking fat loss without losing energy',
          'Seniors needing anti-inflammatory nutrition',
          'Busy professionals needing practical meal strategies',
          'Anyone who has tried generic diets and failed',
        ].map((item) => (
          <div class="flex items-start gap-3 bg-white rounded-2xl p-5 border border-[var(--color-dark)]/8">
            <Icon name="ph:check-circle-fill" class="size-5 text-[var(--color-accent)] shrink-0 mt-0.5" />
            <p class="text-sm leading-relaxed">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-8 md:px-16">
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <img src="/images/nutrition.webp" alt="Licensed nutritionist reviewing meal plan with client at FIT360"
          class="w-full h-[450px] object-cover rounded-3xl" loading="lazy" />
        <div>
          <h2 class="font-[var(--font-drama)] italic text-[clamp(1.8rem,4vw,3rem)] text-[var(--color-primary)] mb-8">What Makes This Different</h2>
          <div class="space-y-6">
            {[
              { title: 'Individual Assessment First', desc: 'We review your medical background, eating patterns, activity level, and lifestyle before any plan is created.', icon: 'ph:clipboard-fill' },
              { title: 'Integrated with Your Training', desc: 'Your meal plan is designed to support your specific workouts, not work against them.', icon: 'ph:link-fill' },
              { title: 'Weekly Check-ins and Adjustments', desc: 'Your nutritionist reviews your food diary every week and adjusts your plan based on real feedback and results.', icon: 'ph:calendar-check-fill' },
              { title: 'Flexible for Real Life', desc: 'We build plans that work when eating out, at social occasions, and within your actual budget and food preferences.', icon: 'ph:fork-knife-fill' },
            ].map((point) => (
              <div class="flex gap-4">
                <div class="w-10 h-10 bg-[var(--color-accent)]/10 rounded-xl flex items-center justify-center shrink-0">
                  <Icon name={point.icon} class="size-5 text-[var(--color-accent)]" />
                </div>
                <div>
                  <h3 class="font-[var(--font-heading)] font-bold mb-1">{point.title}</h3>
                  <p class="text-[var(--color-muted)] text-sm leading-relaxed">{point.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 px-8 md:px-16 bg-[var(--color-primary)]">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-[var(--font-drama)] italic text-[clamp(1.8rem,4vw,3rem)] text-[var(--color-bg)] mb-10">Expected Outcomes</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {[
          'Improved hormonal health and cycle regularity',
          'Sustainable weight management without crash diets',
          'Better blood sugar control and energy levels',
          'Enhanced mental clarity and reduced brain fog',
          'Healthier skin and reduced inflammation',
          'Practical eating habits that last long-term',
        ].map((outcome) => (
          <div class="flex items-start gap-3">
            <Icon name="ph:arrow-right-bold" class="size-5 text-[var(--color-accent)] shrink-0 mt-0.5" />
            <p class="text-[var(--color-bg)]/80 leading-relaxed">{outcome}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-8 md:px-16">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-[var(--font-drama)] italic text-[clamp(1.8rem,4vw,3rem)] text-[var(--color-primary)] mb-10">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-white border border-[var(--color-dark)]/8 rounded-2xl overflow-hidden">
            <summary class="flex items-center justify-between p-6 cursor-pointer font-[var(--font-heading)] font-semibold">
              {faq.question}
              <Icon name="ph:caret-down" class="size-5 text-[var(--color-accent)] group-open:rotate-180 transition-transform" />
            </summary>
            <div class="px-6 pb-6 text-[var(--color-muted)] leading-relaxed">{faq.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 px-8 md:px-16 bg-[var(--color-accent)]">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-[var(--font-drama)] italic text-3xl md:text-5xl text-white mb-4">Start with a Free Consultation</h2>
      <p class="text-white/80 mb-8 text-lg">No commitment. We assess your nutrition needs and show you what a real plan looks like.</p>
      <a href="/contact/" class="btn-magnetic inline-flex bg-white text-[var(--color-accent)] px-10 py-5 rounded-full text-lg font-bold">
        <span class="relative z-10 flex items-center gap-2">Book Free Consultation <Icon name="ph:arrow-right-bold" class="size-5" /></span>
        <span class="btn-bg bg-[var(--color-primary)] rounded-full"></span>
      </a>
    </div>
  </section>

  <Footer />
</BaseLayout>
